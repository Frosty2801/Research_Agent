OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.2

# Current implementation uses mock search results.
# Future valid values can include providers such as tavily, duckduckgo, or google.
DEFAULT_SEARCH_PROVIDER=mock

# Required only when DEFAULT_SEARCH_PROVIDER=tavily.
TAVILY_API_KEY=your_tavily_api_key_here

MEMORY_DIR=src/data/memory
CHROMA_COLLECTION_NAME=research_memory
REPORTS_DIR=src/data/outputs
